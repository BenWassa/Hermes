rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function accessDoc(uid) {
      return get(/databases/$(database)/documents/access/$(uid));
    }

    function isActiveApprovedUser() {
      return isSignedIn()
        && accessDoc(request.auth.uid).exists()
        && accessDoc(request.auth.uid).data.active == true;
    }

    function isAdmin() {
      return isActiveApprovedUser()
        && accessDoc(request.auth.uid).data.role == 'admin';
    }

    match /briefings/{briefingId} {
      allow read: if isActiveApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /syntheses/{synthesisId} {
      allow read: if isActiveApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /amplifiers/{amplifierId} {
      allow read: if isActiveApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /access/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
