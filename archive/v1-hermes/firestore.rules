rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.uid == "aavtqWTiNUZk5NQpDJkvo9IIqh02";
    }

    function isApprovedUser() {
      return isBootstrapAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/access/$(request.auth.uid))
          && get(/databases/$(database)/documents/access/$(request.auth.uid)).data.active == true
        );
    }

    function isAdmin() {
      return isBootstrapAdmin()
        || (
          isApprovedUser()
          && get(/databases/$(database)/documents/access/$(request.auth.uid)).data.role == "admin"
        );
    }

    match /briefings/{briefingId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /syntheses/{synthesisId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /amplifiers/{amplifierId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /access/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
