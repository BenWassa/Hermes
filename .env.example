# The Daily - environment configuration
# Copy to .env for local development (gitignored). CI uses GitHub repo secrets.

# Anthropic API key for curation + summarization
ANTHROPIC_API_KEY=

# The Guardian Open Platform key - https://open-platform.theguardian.com/
GUARDIAN_API_KEY=

# NYT Developer key - https://developer.nytimes.com/
NYT_API_KEY=

# ntfy.sh topic for the morning push (pick something hard to guess)
NTFY_TOPIC=

# Public site URL (used in the cache-buster meta and the notification click action)
PAGES_URL=https://BenWassa.github.io/Hermes/
